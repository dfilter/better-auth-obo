{
  "name": "better-auth-obo",
  "type": "module",
  "version": "0.3.0",
  "description": "A starter for creating a TypeScript package.",
  "author": "Dirk Filter <dirk_filter@outlook.com>",
  "license": "MIT",
  "homepage": "https://github.com/dfilter/better-auth-obo#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dfilter/better-auth-obo.git"
  },
  "bugs": {
    "url": "https://github.com/dfilter/better-auth-obo/issues"
  },
  "exports": {
    ".": "./dist/index.mjs",
    "./package.json": "./package.json"
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "better-auth",
    "On Behalf Of",
    "OBO",
    "Entra ID",
    "Microsoft Entra ID",
